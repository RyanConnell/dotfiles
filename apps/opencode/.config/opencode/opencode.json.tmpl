{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
      {{- $first := true }}
      {{- range $id, $model := .Globals.models }}
        {{- if not $first }},{{ end }}
        "{{ $id }}": {
          "name": "{{ $model.name }}",
          "limit": {
            "context": {{ $model.ctx }},
            "output": {{ $model.max_output }}
          }
        }
        {{- $first = false }}
      {{- end }}
      }
    }
  },
  "model": "{{ .Vars.default_model_id }}",
  "permission": {
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "yarn *": "allow",
      "go *": "allow",
      "kubectl *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "cd *": "allow",
      "mkdir *": "allow",
      "python *": "allow",
      "pip *": "allow",
      "docker *": "allow",
      "tree *": "allow",
      "du *": "allow",
      "df *": "allow",
      "ps *": "allow",
      "top *": "allow",
      "touch *": "allow",
      "rm *": "deny",
      "sudo *": "deny",
      "jq *": "allow"
    }
  }
}
